# ── Single-store frontend config ──────────────────────────────────────
# Copy to .env and customise. In dev, /api and /uploads are proxied to the
# Express server on :3000 (see vite.config.js), so VITE_API_URL can stay empty.

VITE_API_URL=

# Branding / SEO (substituted into index.html at build time)
VITE_STORE_NAME=ELEGANT BAYT
VITE_SITE_TITLE=ELEGANCE AT HOME | ELEGANT BAYT
VITE_STORE_DESC=Elegant Bayt — premium plastic home appliances designed for durability, functionality and style.
VITE_SITE_URL=https://elegantbayt.com
VITE_FAVICON_URL=/favicon.png
VITE_APPLE_TOUCH_ICON=/apple-touch-icon.png
VITE_OG_IMAGE=/images/elegant-bayt-og.png
VITE_THEME_COLOR=#16264d

# Currency — AED (UAE Dirham). The new dirham symbol isn't in fonts, so it's
# rendered from /images/aed.png via VITE_CURRENCY_ICON. The text values below
# are fallbacks/alt-text for non-image contexts.
VITE_CURRENCY_SYMBOL=QAR
VITE_CURRENCY_SYMBOL_AR=ر.ق
VITE_CURRENCY_CODE=QAR
VITE_CURRENCY_DECIMALS=2
VITE_CURRENCY_ICON=QAR

# Feature flags (off by default for the single-store storefront)
VITE_FEATURE_B2B=false
VITE_FEATURE_SHIPROCKET_CHECKOUT=false
VITE_FEATURE_MULTILOC=false
VITE_FEATURE_I18N=true

# Optional Google OAuth client id (enables the Google login button)
VITE_GOOGLE_CLIENT_ID=

# Tamara promotional widget ("Pay in 4" messaging on product/cart pages).
# Disabled: Tamara is UAE/KSA-only (not Qatar) and rendered an AED dirham glyph.
# Store uses Tap Payments + QAR. Leave the public key empty to hide the widget.
VITE_TAMARA_PUBLIC_KEY=
VITE_TAMARA_WIDGET_COUNTRY=QA
