# ── Single-store frontend config ──────────────────────────────────────
# In dev, /api and /uploads are proxied to the Express server on :5000
# (see vite.config.js), so VITE_API_URL can stay empty.

VITE_API_URL=

# Branding / SEO (substituted into index.html at build time)
VITE_STORE_NAME=JOKER PERFUMES
VITE_SITE_TITLE=JOKER PERFUMES | Luxury Fragrances
VITE_STORE_DESC=Joker Perfumes — luxury oriental and niche fragrances, oud, attars and eau de parfum crafted to leave a lasting impression.
VITE_SITE_URL=http://localhost:5173
VITE_FAVICON_URL=/favicon.png
VITE_APPLE_TOUCH_ICON=/apple-touch-icon.png
VITE_OG_IMAGE=/images/joker-perfumes-og.png
# Quoted — an unquoted leading '#' is parsed as a dotenv comment, which
# silently emptied this value.
VITE_THEME_COLOR="#1a1a2e"

# Currency — SAR (Saudi Riyal)
VITE_CURRENCY_SYMBOL=SAR
VITE_CURRENCY_SYMBOL_AR=ر.س
VITE_CURRENCY_CODE=SAR
VITE_CURRENCY_DECIMALS=2
VITE_CURRENCY_ICON=SAR

# Feature flags (off by default for the single-store storefront)
VITE_FEATURE_B2B=false
VITE_FEATURE_SHIPROCKET_CHECKOUT=false
VITE_FEATURE_MULTILOC=false
VITE_FEATURE_I18N=true

# Optional Google OAuth client id (enables the Google login button)
VITE_GOOGLE_CLIENT_ID=

# Tamara promotional widget — leave the public key empty to hide it
VITE_TAMARA_PUBLIC_KEY=
VITE_TAMARA_WIDGET_COUNTRY=SA
